FROM golang:1.24-alpine AS builder
RUN apk add --no-cache git
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /zsend ./cmd/zsend/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /zsend /usr/local/bin/zsend
ENTRYPOINT ["zsend"]
